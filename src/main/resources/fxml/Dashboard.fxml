<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.DashboardController">

    <!-- TOP HEADER -->
    <top>
        <HBox spacing="10"
              alignment="CENTER_LEFT"
              BorderPane.alignment="CENTER"
              styleClass="header-bar">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="ScrobbleDash" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>

            <CheckBox fx:id="autoRefreshCheck" text="Auto-refresh"/>
            <ComboBox fx:id="autoRefreshSeconds" prefWidth="90" promptText="Seconds"/>

            <ProgressIndicator fx:id="progress" visible="false" prefWidth="22" prefHeight="22"/>

            <!-- optional primary style -->
            <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh" styleClass="primary"/>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="10">
            <padding>
                <Insets right="12" bottom="12" left="12"/>
            </padding>

            <TabPane fx:id="tabs" VBox.vgrow="ALWAYS">
                <tabs>

                    <!-- RECENT TRACKS -->
                    <Tab text="Recent Tracks" closable="false">
                        <VBox spacing="10">
                            <TableView fx:id="tracksTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="artCol" text="Art" prefWidth="60"/>
                                    <TableColumn fx:id="trackCol" text="Track" prefWidth="240"/>
                                    <TableColumn fx:id="artistCol" text="Artist" prefWidth="200"/>
                                    <TableColumn fx:id="albumCol" text="Album" prefWidth="220"/>
                                    <TableColumn fx:id="whenCol" text="When" prefWidth="160"/>
                                </columns>
                            </TableView>

                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="loadMoreButton" text="Load More" onAction="#onLoadMore"/>
                            </HBox>
                        </VBox>
                    </Tab>

                    <!-- TOP ARTISTS -->
                    <Tab text="Top Artists" closable="false">
                        <VBox spacing="10">
                            <TableView fx:id="artistsTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="artistArtCol" text="Art" prefWidth="60"/>
                                    <TableColumn fx:id="topArtistCol" text="Artist" prefWidth="420"/>
                                    <TableColumn fx:id="playcountCol" text="Plays" prefWidth="140"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </Tab>

                </tabs>
            </TabPane>

            <Label fx:id="statusLabel" text="Ready." styleClass="status-label"/>
        </VBox>
    </center>

    <!-- NOW PLAYING BAR -->
    <bottom>
        <HBox fx:id="nowPlayingBar"
              spacing="12"
              alignment="CENTER_LEFT"
              BorderPane.alignment="CENTER"
              styleClass="now-playing-bar"
              visible="false"
              managed="false">
            <padding>
                <Insets top="10" right="12" bottom="10" left="12"/>
            </padding>

            <ImageView fx:id="nowPlayingArt" fitWidth="48" fitHeight="48" preserveRatio="true"/>

            <VBox spacing="2">
                <Label fx:id="nowPlayingTitle" text="Track" styleClass="now-playing-title"/>
                <Label fx:id="nowPlayingArtist" text="Artist" styleClass="now-playing-artist"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="nowPlayingStatus" text="Now Playing" styleClass="now-playing-badge"/>

            <Button text="Refresh" onAction="#onRefresh"/>
        </HBox>
    </bottom>

</BorderPane>
